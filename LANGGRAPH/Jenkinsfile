pipeline {
  agent any
  environment {
    BACKEND_IMAGE = 'langgraph-backend:latest'
    FRONTEND_IMAGE = 'langgraph-frontend:latest'
  }
  stages {
    stage('Checkout') {
      steps {
        checkout scm
      }
    }
    stage('Verify Toolchain') {
      steps {
        sh 'echo "Checking toolchain"'
        sh 'docker --version'
        sh 'docker compose version'
        sh 'node --version || true'
        sh 'npm --version || true'
        sh 'python --version || true'
        sh 'pip --version || true'
      }
    }
    stage('Load Environment from Jenkins Credentials') {
      steps {
        script {
          withCredentials([file(credentialsId: 'ENV', variable: 'ENV_FILE')]) {
            sh 'cp "$ENV_FILE" .env'
          }
        }
      }
    }
    stage('Front-end Pipeline') {
      steps {
        dir('frontend') {
          sh 'npm ci'
          sh 'npm run build'
          sh 'npm test'
        }
        sh "docker build -t ${env.FRONTEND_IMAGE} ./frontend"
      }
    }
    stage('Back-end Pipeline') {
      steps {
        dir('backend') {
          sh 'pip install -r requirements.txt'
          sh 'pytest -q'
        }
        sh "docker build -t ${env.BACKEND_IMAGE} -f backend/Dockerfile ."
      }
    }
    stage('Agentic Orchestration Pipeline') {
      steps {
        dir('orchestration') {
          sh 'docker build -t langgraph_orchestration .'
        }
        sh 'docker compose build'
        sh 'docker compose up -d'
        sh 'docker compose ps'
      }
    }
  }
  post {
    always {
      sh 'docker compose down || true'
    }
  }
}
